# Supabase (von supabase.com → Project Settings → API)
PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...dein-anon-key

# E-Mail-Benachrichtigung bei neuem Survey (Edge Function notify-email, via Resend)
# In Supabase Dashboard → Edge Functions → Secrets, oder: supabase secrets set KEY=value
# RESEND_API_KEY=re_xxxxxxxx           # von resend.com → API Keys
# NOTIFY_EMAIL_TO=danielepauli@gmail.com
# NOTIFY_EMAIL_FROM=Survey <noreply@danielepauli.com>   # oder zum Testen: onboarding@resend.dev
# SITE_URL=https://danielepauli.com

# Twilio (OPTIONAL – nur falls zusätzlich WhatsApp-Benachrichtigung gewünscht)
# Diese werden in Supabase Dashboard → Edge Functions → Secrets gesetzt:
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# DANI_WHATSAPP_TO=whatsapp:+41798675705
# SITE_URL=https://danielepauli.com
