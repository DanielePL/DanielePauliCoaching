---
// Testimonials section
// WICHTIG: Nur ECHTE Kundenstimmen verwenden. Keine erfundenen Testimonials
// (in CH/EU rechtswidrig – UWG Art. 3 / EU-Fake-Review-Verbot).
// Echte Fotos nur mit Einwilligung des Kunden; sonst bleibt `photo: null`
// und es wird ein Initial-Avatar angezeigt.
const testimonials = [
  {
    quote: "Ich habe mein Unternehmen skaliert, aber mein Körper war im Verfall. Daniele hat mir geholfen, Energie, Fokus und Kraft wieder aufzubauen.",
    name: "Tobias, 52",
    role: "Unternehmer",
    initials: "T",
    photo: null,
    results: ["Mehr Energie im Arbeitsalltag", "Rückenschmerzen weg", "Spürbar stärker & belastbarer"]
  },
  {
    quote: "Früher habe ich einfach 'trainiert'. Jetzt mit Ziel – schlanker, mehr Energie, keine Schmerzen mehr.",
    name: "Sabine, 46",
    role: "Selbstständig",
    initials: "S",
    photo: null,
    results: ["8% Körperfett verloren", "Deutlich mehr Energie", "Schulterprobleme gelöst"]
  },
  {
    quote: "Ich arbeite seit einigen Monaten mit Daniele und habe bereits aussergewöhnliche Resultate erzielt. Ein absoluter Profi auf seinem Gebiet.",
    name: "Nora T.",
    role: "Unternehmerin",
    initials: "N",
    photo: null,
    results: ["Sichtbare Resultate in Wochen", "Endlich dran geblieben"]
  }
];
---

<section class="section" id="testimonials">
  <div class="section-container">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <h2 class="heading-lg mb-6">
        <span class="gradient-text">"Ich fühle mich wieder wie ich selbst."</span>
      </h2>
      <p class="text-xl text-text-secondary">
        Echte Menschen, echte Resultate – mehr Energie, weniger Schmerzen, ein klarer Kopf
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((testimonial, index) => (
        <div
          class="glass-card overflow-hidden flex flex-col"
          data-animate
          style={`transition-delay: ${index * 100}ms`}
        >
          <!-- Quote -->
          <div class="p-6 flex-grow relative">
            <span class="absolute top-4 left-4 text-6xl text-orange/10 font-serif">"</span>
            <p class="text-text-primary relative z-10 italic mb-6 pt-4">
              {testimonial.quote}
            </p>

            <!-- Author -->
            <div class="flex justify-between items-end">
              <div class="flex items-center gap-3">
                <!-- Avatar: echtes Foto (mit Einwilligung) oder Initial -->
                {testimonial.photo ? (
                  <img src={testimonial.photo} alt={testimonial.name} class="w-10 h-10 rounded-full object-cover" loading="lazy" />
                ) : (
                  <span class="w-10 h-10 rounded-full bg-orange/15 text-orange font-bold flex items-center justify-center text-sm">
                    {testimonial.initials}
                  </span>
                )}
                <div>
                  <p class="font-bold text-orange leading-tight">{testimonial.name}</p>
                  {testimonial.role && (
                    <p class="text-text-secondary text-sm">{testimonial.role}</p>
                  )}
                </div>
              </div>
              <div class="text-orange">★★★★★</div>
            </div>
          </div>

          <!-- Results -->
          {testimonial.results.length > 0 && (
            <div class="bg-surface/50 p-4 border-t border-glass-border">
              <p class="text-xs text-text-secondary font-bold mb-2 uppercase tracking-wide">
                Messbare Resultate:
              </p>
              <ul class="space-y-1">
                {testimonial.results.map((result) => (
                  <li class="text-sm text-text-secondary flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-orange rounded-full"></span>
                    {result}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
