---
// Säulen-Sektion — die 4 Säulen des ganzheitlichen Coachings
// Siehe "konzept 2026.md" Abschnitt 3. Ersetzt den Kraftsport-Monofokus.
const saeulen = [
  {
    title: "Körper & Kraft",
    description: "Training, das in deinen Alltag passt. Kraft als Mittel für mehr Energie und weniger Schmerzen – nicht als Selbstzweck.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`
  },
  {
    title: "Mental & Mindset",
    description: "Oft der entscheidende Hebel. Stress runter, Klarheit rauf – damit Dranbleiben nicht von Willenskraft allein abhängt.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`
  },
  {
    title: "Ernährung",
    description: "Alltagstauglich essen – ohne Verzicht, ohne Crash-Diät, ohne Jo-Jo. Inklusive ehrlichem Blick auf Alkohol.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`
  },
  {
    title: "Lifestyle",
    description: "Besserer Schlaf, klügere Routinen, echte Regeneration. Die Basis, auf der alles andere überhaupt erst hält.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>`
  }
];
---

<section class="section" id="saeulen">
  <div class="section-container">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <h2 class="heading-lg mb-6">
        Vier Säulen.
        <span class="gradient-text">Ein System.</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">
        Nicht nur Training. Körper, Kopf, Ernährung und Alltag greifen ineinander –
        genau da entstehen Ergebnisse, die halten.
      </p>
    </div>

    <!-- Säulen Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {saeulen.map((saeule, index) => (
        <div
          class="glass-card glass-hover p-8 h-full"
          data-animate
          style={`transition-delay: ${index * 100}ms`}
        >
          <div class="text-orange mb-4" set:html={saeule.icon} />
          <h3 class="text-xl font-bold text-text-primary mb-3">{saeule.title}</h3>
          <p class="text-text-secondary">{saeule.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
